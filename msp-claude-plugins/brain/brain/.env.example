# Brain MCP — Organizational Knowledge Layer
# The brain-mcp server runs as a separate process; point Claude at it via MCP config.
# See: https://github.com/wyre-technology/brain-mcp

# For Claude Desktop / Claude Code stdio transport, add to claude_desktop_config.json:
# {
#   "mcpServers": {
#     "brain": {
#       "command": "npx",
#       "args": ["-y", "@wyre-technology/brain-mcp"],
#       "env": {
#         "BRAIN_DATABASE_URL": "postgresql://user:password@host:5432/brain",
#         "BRAIN_SYNC_SOURCES": "autotask,itglue,datto_rmm",
#         "REDIS_URL": "redis://localhost:6379"
#       }
#     }
#   }
