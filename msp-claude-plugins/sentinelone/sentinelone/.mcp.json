{
  "mcpServers": {
    "sentinelone": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Sentinel-One/purple-mcp.git",
        "purple-mcp",
        "--mode",
        "stdio"
      ],
      "env": {
        "PURPLEMCP_CONSOLE_TOKEN": "${SENTINELONE_TOKEN}",
        "PURPLEMCP_CONSOLE_BASE_URL": "${SENTINELONE_BASE_URL}"
      },
      "note": "SentinelOne Purple AI MCP server. Requires Account/Site-level Service User token (NOT Global)."
    }
  }
}
