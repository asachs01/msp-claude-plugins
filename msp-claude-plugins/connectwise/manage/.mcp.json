{
  "mcpServers": {
    "connectwise-manage": {
      "type": "http",
      "url": "${CONNECTWISE_MANAGE_MCP_URL}",
      "headers": {
        "X-CW-Company-ID": "${CW_MANAGE_COMPANY_ID}",
        "X-CW-Public-Key": "${CW_MANAGE_PUBLIC_KEY}",
        "X-CW-Private-Key": "${CW_MANAGE_PRIVATE_KEY}",
        "X-CW-Client-ID": "${CW_MANAGE_CLIENT_ID}",
        "X-CW-URL": "${CW_MANAGE_URL}"
      }
    }
  }
}
